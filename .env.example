# ============================================================
# Signal — Market Demand Validation Platform
# API Keys Configuration
# ============================================================
# Copy this file to .env.local and fill in your keys.
# cp .env.example .env.local
# ============================================================

# ---- LLM Provider (required for signal classification & scoring) ----
# Choose one:
#   Claude:  ANTHROPIC_API_KEY
#   OpenAI:  OPENAI_API_KEY
#   Both optional if using local mock mode
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# ---- Signal Sources ----
# Reddit — free API, apply at https://reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Hacker News — free Firebase API, no key required (works out of the box)
# Product Hunt — apply at https://api.producthunt.com/v2/docs
PRODUCTHUNT_API_KEY=

# Google Trends — requires pyTrends (local) or SerpAPI
SERPAPI_KEY=

# ---- Email (for alerts & weekly digest) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3100
DATABASE_URL="file:./dev.db"
