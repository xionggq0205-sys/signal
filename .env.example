# ============================================================
# Signal — Market Demand Validation Platform
# API Keys Configuration
# ============================================================
# Copy: cp .env.example .env.local
# 详细说明: outputs/signal-api-guide.md
# ============================================================
#
# ╔══════════════════════════════════════════════════════════╗
# ║ 零配置即可运行！Hacker News + Reddit + Fiverr/Upwork    ║
# ║ 都不需要 API Key。规则引擎替代 LLM 做分类。             ║
# ║ 以下所有 Key 都是可选的增强项。                          ║
# ╚══════════════════════════════════════════════════════════╝

# ─── 必须配置 ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3100
DATABASE_URL="file:./dev.db"

# ─── 数据源（全部可选，无 Key 也能工作）──────────────
# Reddit OAuth — 提升速率限制（10→60 req/min），无 Key 也能用
# 获取: https://reddit.com/prefs/apps → create app → type: script
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Product Hunt v2 API — v1 公开端点可能已废弃
# 获取: https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_KEY=
PRODUCTHUNT_API_SECRET=

# Google Trends via SerpAPI — 替换不稳定的非官方 API
# 获取: https://serpapi.com/ （免费额度 100次/月）
SERPAPI_KEY=

# ─── LLM 增强分类（可选，内置规则引擎已生效）────────
# Claude: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── 邮件通知（Phase 5 功能，尚未开发）───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
